{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "stream",
    "tasks": {
        "build": {
            "cache": true,
            "dependsOn": [
                "^build"
            ]
        },
        "typecheck": {
            "cache": true,
            "dependsOn": [
                "^typecheck"
            ]
        },
        "format": {
            "cache": true,
            "dependsOn": [
                "^format"
            ],
            "inputs": [
                "./**.ts",
                "$TURBO_DEFAULT$"
            ]
        },
        "check-types": {
            "cache": true,
            "dependsOn": [
                "^check-types"
            ]
        }
    }
}