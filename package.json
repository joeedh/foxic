{
  "name": "gametest",
  "type": "module",
  "scripts": {
    "dev": "cd src && pnpm dev",
    "build": "npx tsgo",
    "format": "npx \"@pathtx/prettier\" --write src/",
    "playwright": "npx playwright test",
    "typecheck": "npx tsgo --noEmit"
  },
  "devDependencies": {
    "@pathtx/prettier": "3.3.0-dev",
    "@playwright/test": "^1.59.1",
    "@typescript/native-preview": "7.0.0-dev.20260414.1",
    "mcp-image": "^0.10.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/**",
    "src"
  ]
}