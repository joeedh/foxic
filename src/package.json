{
  "name": "@gametest/main",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/@gametest/esbuild-serve/serv.js serv",
    "build": "",
    "format": "node node_modules/@pathtx/prettier/bin/prettier.cjs --log-level warn --cache --write ./ ../public/index.html",
    "format:check": "node node_modules/@pathtx/prettier/bin/prettier.cjs --log-level warn --cache --check ./ ../public/index.html",
    "playwright": "npx playwright test",
    "typecheck": "npx tsgo --noEmit"
  },
  "devDependencies": {
    "@gametest/tsconfig": "workspace:*",
    "@gametest/utils": "workspace:*",
    "@pathtx/prettier": "3.3.0-dev",
    "@playwright/test": "^1.59.1",
    "@typescript/native-preview": "7.0.0-dev.20260414.1",
    "@gametest/esbuild-serve": "workspace:*",
    "mcp-image": "^0.10.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.30.3"
}
